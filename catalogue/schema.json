{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "TLS Fingerprint Catalogue Entry",
  "type": "object",
  "required": [
    "runtime",
    "runtime_version",
    "http_client",
    "http_client_version",
    "os",
    "tls_library",
    "ja4",
    "alpn_present",
    "captured_at"
  ],
  "properties": {
    "runtime":             { "type": "string", "minLength": 1 },
    "runtime_version":     { "type": "string", "minLength": 1 },
    "http_client":         { "type": "string", "minLength": 1 },
    "http_client_version": { "type": "string", "minLength": 1 },
    "os":                  { "type": "string", "minLength": 1 },
    "tls_library":         { "type": "string", "minLength": 1 },
    "ja4":                 { "type": "string", "minLength": 1 },
    "alpn_present":        { "type": "boolean" },
    "captured_at":         { "type": "string", "minLength": 1 },
    "client_type": {
      "type": "string",
      "enum": ["agent", "tool", "headless", "browser", "unknown"],
      "description": "How the proxy should classify and route this client. Optional for backward compatibility — lookup.py defaults to 'agent' when absent."
    }
  },
  "additionalProperties": false
}
